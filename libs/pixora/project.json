{
  "name": "pixora",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/pixora/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "generate-llmstxt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/generate-llmstxt.mjs"
      }
    },
    "build": {
      "dependsOn": ["generate-llmstxt"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
