---
import DocsShell from '../layouts/docs-shell.astro';
import { withBasePath } from '../lib/docs';

const basePath = import.meta.env.BASE_URL;
---

<DocsShell currentPath={Astro.url.pathname} title="Pixora">
  <div class="py-12">
    <section class="mb-20 text-center">
      <div
        class="bg-primary/10 border-primary/20 text-primary mb-6 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-bold tracking-wider uppercase"
      >
        <span class="relative flex h-2 w-2">
          <span class="bg-primary absolute inline-flex h-full w-full animate-ping rounded-full opacity-75"></span>
          <span class="bg-primary relative inline-flex h-2 w-2 rounded-full"></span>
        </span>
        v0.7.4 Engine Release
      </div>
      <h1
        class="mb-6 text-5xl leading-[1.1] font-bold tracking-tight text-slate-900 lg:text-7xl dark:text-white"
      >
        The Framework for
        <span class="from-primary to-purple-400 bg-gradient-to-r bg-clip-text text-transparent">
          High-Performance
        </span>
        Rendering
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
        Pixora is a system-driven engine architected for precision and speed. Build modern web interfaces with a
        developer-first mental model and engine-level transparency.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          class="bg-primary shadow-primary/20 flex h-12 items-center gap-2 rounded-lg px-8 font-bold text-white transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg"
          href={withBasePath(basePath, 'docs/getting-started/')}
        >
          Get Started
          <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <a
          class="dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 h-12 rounded-lg border border-slate-300 bg-white px-8 font-bold text-slate-700 transition-all hover:bg-slate-50"
          href={withBasePath(basePath, 'docs/api/')}
        >
          View Documentation
        </a>
      </div>
    </section>

    <section class="mb-20">
      <div class="mb-12 flex flex-col items-center">
        <h2 class="mb-2 text-sm font-bold tracking-[0.2em] text-slate-400 uppercase">Architecture</h2>
        <h3 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Engineered for Clarity</h3>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <div
          class="dark:border-slate-800 dark:bg-slate-800/50 group rounded-xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:border-primary/50 hover:shadow-md"
        >
          <div
            class="bg-primary/5 border-primary/10 group-hover:bg-primary/10 mb-6 flex size-12 items-center justify-center rounded-lg border transition-all"
          >
            <span class="material-symbols-outlined text-primary">dynamic_form</span>
          </div>
          <h4 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">Unified Pipeline</h4>
          <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            A single source of truth for your rendering logic. No more synchronization issues between state and view
            layers.
          </p>
        </div>
        <div
          class="dark:border-slate-800 dark:bg-slate-800/50 group rounded-xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:border-primary/50 hover:shadow-md"
        >
          <div
            class="bg-primary/5 border-primary/10 group-hover:bg-primary/10 mb-6 flex size-12 items-center justify-center rounded-lg border transition-all"
          >
            <span class="material-symbols-outlined text-primary">security</span>
          </div>
          <h4 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">Type-Safe Props</h4>
          <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            Deep integration with TypeScript for error-free development. Compile-time checks for all your rendering
            parameters.
          </p>
        </div>
        <div
          class="dark:border-slate-800 dark:bg-slate-800/50 group rounded-xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:border-primary/50 hover:shadow-md"
        >
          <div
            class="bg-primary/5 border-primary/10 group-hover:bg-primary/10 mb-6 flex size-12 items-center justify-center rounded-lg border transition-all"
          >
            <span class="material-symbols-outlined text-primary">account_tree</span>
          </div>
          <h4 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">Node-Based Inspector</h4>
          <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            Visualize your component tree with engine-level precision. Debug layout shifts and paint cycles in
            real-time.
          </p>
        </div>
      </div>
    </section>

    <section class="mb-20">
      <div class="dark:bg-slate-800/50 overflow-hidden rounded-2xl bg-slate-100 p-px">
        <div class="rounded-[calc(1rem-1px)] bg-white p-8 dark:bg-slate-900">
          <div class="grid grid-cols-2 gap-8 text-center md:grid-cols-4">
            <div class="flex flex-col gap-1">
              <span class="text-primary text-3xl font-bold">0.4ms</span>
              <span class="text-xs font-bold tracking-widest text-slate-500 uppercase">Latency</span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-primary text-3xl font-bold">120fps</span>
              <span class="text-xs font-bold tracking-widest text-slate-500 uppercase">Refresh Rate</span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-primary text-3xl font-bold">2.4kb</span>
              <span class="text-xs font-bold tracking-widest text-slate-500 uppercase">Runtime Size</span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-primary text-3xl font-bold">99%</span>
              <span class="text-xs font-bold tracking-widest text-slate-500 uppercase">Type Coverage</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 text-center">
      <div class="relative overflow-hidden rounded-3xl py-20">
        <div class="bg-primary/[0.03] border-primary/10 absolute inset-0 rounded-3xl border"></div>
        <div class="relative z-10 flex flex-col items-center gap-6 px-4">
          <h2 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl dark:text-white">
            Ready to architect the future?
          </h2>
          <p class="mx-auto max-w-md text-slate-600 dark:text-slate-400">
            Join the next generation of developers building high-performance web experiences with Pixora.
          </p>
          <div class="mt-4 flex gap-4">
            <a
              class="bg-primary hover:shadow-primary/30 flex h-14 items-center gap-2 rounded-xl px-10 font-bold text-white transition-all hover:shadow-lg"
              href={withBasePath(basePath, 'docs/getting-started/')}
            >
              Start Building
              <span class="material-symbols-outlined">rocket_launch</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</DocsShell>
