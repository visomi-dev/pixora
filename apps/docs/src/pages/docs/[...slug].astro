---
import DocPage from '../../components/doc-page.astro';
import { getAllDocs, getDocBySlug, getSectionChildren, withBasePath } from '../../lib/docs';

export function getStaticPaths() {
  return getAllDocs()
    .filter((entry) => entry.slug)
    .map((entry) => ({
      params: {
        slug: entry.slug,
      },
    }));
}

const slug = Astro.params.slug ?? '';
const entry = getDocBySlug(slug);
const basePath = import.meta.env.BASE_URL;

if (!entry) {
  throw new Error(`The documentation page "${slug}" is missing.`);
}

const children = entry.isSection ? getSectionChildren(entry.slug) : [];
---

<DocPage currentPath={Astro.url.pathname} entry={entry}>
  {
    children.map((child) => (
      <li>
        <a
          class="hover:border-primary/50 dark:border-slate-800 dark:hover:bg-white/5 block rounded-xl border border-slate-200 p-4 transition-all hover:bg-slate-50"
          href={withBasePath(basePath, child.href)}
        >
          <h2 class="mb-2 text-lg font-bold text-slate-900 dark:text-white">{child.title}</h2>
          {child.description && <p class="text-sm text-slate-600 dark:text-slate-400">{child.description}</p>}
        </a>
      </li>
    ))
  }
</DocPage>
