{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo -d ../../dist/apps/docs --gc --minify",
        "cwd": "apps/docs"
      },
      "dependsOn": ["build-example"]
    },
    "build-example": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx build space-invaders --skip-nx-cache && mkdir -p static/examples/game && cp -r ../../dist/apps/space-invaders/* static/examples/game/ && rm -rf ../../dist/apps/space-invaders && sed -i 's|/assets/|assets/|g' static/examples/game/index.html",
        "cwd": "apps/docs"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo server -D",
        "cwd": "apps/docs",
        "port": 1313
      },
      "dependsOn": ["api", "build-example"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "hugo -d ../../dist/apps/docs-preview --gc --minify --baseURL /preview/",
        "cwd": "apps/docs"
      },
      "dependsOn": ["api"]
    },
    "api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec typedoc",
        "cwd": "apps/docs"
      }
    }
  }
}
